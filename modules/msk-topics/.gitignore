# Terraform local state — never commit state files
*.tfstate
*.tfstate.backup

# Terraform working directory — generated by terraform init
.terraform/

# Terraform override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# NOTE: .terraform.lock.hcl should be committed to pin provider versions.
# Do NOT add it here.

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo
.claude/
.specify/
